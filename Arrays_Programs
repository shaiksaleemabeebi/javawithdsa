8. Find Second Highest Salary :
-------------------------------------------------------

int[] arr = {20, 40, 80, 60, 90};

int largest = Integer.MIN_VALUE;
int second = Integer.MIN_VALUE;

for(int num : arr)
{
    if(num > largest)
    {
        second = largest;
        largest = num;
    }
    else if(num > second && num != largest)
    {
        second = num;
    }
}

System.out.println(second);


