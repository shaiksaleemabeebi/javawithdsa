13.REVERSE A NUMBER :(WHILE LOOP)
----------------------------------------
int n = 1234;
int rev = 0;

while(n > 0)
{
    int r = n % 10;
    rev = rev * 10 + r;
    n /= 10;
}

System.out.println(rev);


14.PALINDROME NUMBER :(WHILE & IF-ELSE)
----------------------------------------------
int n = 121;
int temp = n;
int rev = 0;

while(n > 0)
{
    int r = n % 10;
    rev = rev * 10 + r;
    n /= 10;
}

if(temp == rev)
    System.out.println("Palindrome");
else
    System.out.println("Not Palindrome");


15.ARMSTRONG NUMBER :(WHILE & IF-ELSE)
----------------------------------------------
int n = 153;
int temp = n;
int sum = 0;

while(n > 0)
{
    int r = n % 10;
    sum += r*r*r;
    n /= 10;
}

if(sum == temp)
    System.out.println("Armstrong");
else
    System.out.println("Not Armstrong");


16.PRIME NUMBER :(FOR LOOP ,BREAK &IF-ELSE)
---------------------------------------------
int n = 13;
boolean prime = true;

for(int i=2;i<=n/2;i++)
{
    if(n%i==0)
    {
        prime=false;
        break;
    }
}

if(prime && n>1)
    System.out.println("Prime");
else
    System.out.println("Not Prime");


