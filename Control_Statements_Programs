8. CALCULATOR USING SWITCH :
----------------------------------------------
int a = 10, b = 5;
char op = '+';

switch(op)
{
    case '+':
        System.out.println(a+b);
        break;

    case '-':
        System.out.println(a-b);
        break;

    case '*':
        System.out.println(a*b);
        break;

    case '/':
        System.out.println(a/b);
        break;

    default:
        System.out.println("Invalid");
}


