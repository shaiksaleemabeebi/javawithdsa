1. CHECK EVEN OR ODD :(IF-ELSE)
-----------------------------------------
import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int n = sc.nextInt();

        if(n % 2 == 0)
            System.out.println("Even");
        else
            System.out.println("Odd");
    }
}


